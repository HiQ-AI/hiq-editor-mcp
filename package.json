{
  "name": "@hiq-ai/hiq-editor-mcp",
  "version": "0.1.0",
  "description": "Open local stdio MCP client for the HiQ LCA dataset editor — forwards business operations to the editor server's HTTP API and adds local UPR-template / file tools.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hiq-editor-mcp": "./dist/server.js",
    "hiq-editor": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/server.js",
    "./server": "./dist/server.js",
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "xlsx": "^0.18.5",
    "yargs": "^18.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.32",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiQ-AI/hiq-editor-mcp.git"
  },
  "homepage": "https://github.com/HiQ-AI/hiq-editor-mcp#readme",
  "bugs": "https://github.com/HiQ-AI/hiq-editor-mcp/issues",
  "keywords": [
    "mcp",
    "lca",
    "carbon-footprint",
    "hiq",
    "editor",
    "cortex"
  ]
}
